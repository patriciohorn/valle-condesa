---
import { Image } from "astro:assets"
const {image, imageAlt, title, description} = Astro.props

---

<div class="flex flex-col md:flex-row gap-6 rounded-2xl bg-white shadow-sm p-2 overflow-hidden">
  <div class="relative aspect-square min-h-80 shrink-0 rounded-lg overflow-hidden">
    <Image src={image} alt={ imageAlt || title} class="absolute inset-0 w-full h-full object-cover object-center" inferSize/>
 </div>
  <div class="flex flex-col justify-center gap-3 md:gap-4 px-4 md:px-0 pb-4">
    <h4 class="text-xl font-medium text-heading">{title}</h4>
    <p class="text-base text-slate-600">{description}</p>
  </div>
</div>