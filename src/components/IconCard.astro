---
import { Image } from "astro:assets"
const {image, label} = Astro.props
---


<div class="flex flex-col gap-4 items-center">
  <div class="bg-white rounded-full w-10 h-10 flex items-center justify-center">
    <Image src={image} alt="" width="32" height="32" class="w-8 h-8"/>
  </div>
  <p class="text-base text-slate-600 text-center text-balance">{label}</p>
</div>