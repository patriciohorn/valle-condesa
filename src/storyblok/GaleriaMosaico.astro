---
import { Image } from "astro:assets"
import SectionWrapper from "../components/SectionWrapper.astro"

const { blok } = Astro.props
---

<SectionWrapper>
  <div class=" py-16 md:py-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-x-6 md:gap-y-0 items-center">

      <div class="relative aspect-3/4 rounded-tl-[150px] rounded-tr-[150px] rounded-b-md overflow-hidden shadow-sm ">
        <Image
          src={blok.imagen_1.filename}
          alt={blok.imagen_1.alt ?? ""}
          width={800}
          height={1067}
          class="absolute inset-0 w-full h-full scale-105 object-cover object-center"
        />
      </div>

      <div class="relative aspect-square rounded-2xl overflow-hidden shadow-sm">
        <Image
          src={blok.imagen_2.filename}
          alt={blok.imagen_2.alt ?? ""}
          width={800}
          height={800}
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      </div>

      <div class="relative aspect-3/4 rounded-bl-[150px] rounded-br-[150px] rounded-t-md overflow-hidden shadow-sm">
        <Image
          src={blok.imagen_3.filename}
          alt={blok.imagen_3.alt ?? ""}
          width={800}
          height={1067}
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      </div>

      <div class="relative aspect-square rounded-2xl overflow-hidden shadow-sm">
        <Image
          src={blok.imagen_4.filename}
          alt={blok.imagen_4.alt ?? ""}
          width={800}
          height={800}
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      </div>

    </div>
  </div>
</SectionWrapper>