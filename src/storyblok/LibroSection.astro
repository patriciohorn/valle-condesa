---
import SectionWrapper from "../components/SectionWrapper.astro"
import { Image } from "astro:assets"
import { renderRichText } from "@storyblok/astro"
const {blok} = Astro.props
const renderedText = blok.text ? renderRichText(blok.text) : ""
---

<section class="bg-[#FCFCF9]">
  <div class="max-w-7xl mx-auto px-5 lg:px-0">
   <div class="py-16 md:py-24 grid md:grid-cols-[1fr_1.5fr] items-center gap-x-16 gap-y-12 relative">
    <!-- Content -->
    <div>
      <h3 class="mb-5 md:mb-6 text-2xl md:text-3xl leading-[1.1] font-medium text-heading">{blok.headline}</h3>
      <div class="prose-slate prose prose-p:leading-normal md:prose-lg ">
        <Fragment set:html={renderedText}/>
      </div>
       <ul class="mt-6 flex flex-col space-y-2 pl-4">
        {blok.items?.map((item : any) => (
          <li class="flex items-center gap-x-4"> 
            <div class="bg-white rounded-full w-10 h-10 flex items-center justify-center border border-accent/10">
              <Image src={item.icon.filename} alt="" width="24" height="24" class="w-6 h-6"/>
            </div>
            <p class="text-slate-600 text-lg">{item.label}</p>
          </li>
        ))}
      </ul>
    </div>
    <!-- Image -->
    <div class="relative aspect-4/3 rounded-2xl overflow-hidden  shadow-sm">
      <Image src={blok.image.filename} alt={blok.image.alt} class="absolute inset-0 object-cover object-center w-full h-full" inferSize/>
    </div>
     <Image src={blok.decor_image.filename} alt={blok.image.alt} class="absolute bottom-14 -right-14 w-60 h-60" inferSize/>
     
     
  </div> 
</section>
