---
import HorizontalCard from "../components/HorizontalCard.astro";
import SectionWrapper from "../components/SectionWrapper.astro";
const {blok} = Astro.props
---

<SectionWrapper>
  <div class="py-20 md:py-24">
    <!-- Header -->
  <div class="mb-12 md:mb-16 flex flex-col items-center">
    <h3 class="text-center text-2xl md:text-3xl leading-[1.1] font-medium text-heading mb-5 md:mb-4 ">{blok.headline}</h3>
    <p class="text-slate-600 text-lg text-center">{blok.description}</p>   
  </div>  
   <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      {blok.cards.map((card : any) => (
      <HorizontalCard image={card.image.filename} title={card.title} description={card.description} />
    ))}
  </div>

  </div>
</SectionWrapper>