---
import { Image } from "astro:assets"
const {blok, isFirstOfLastRow} = Astro.props
---
<div class={`${isFirstOfLastRow ? 'md:col-start-2' : ''} md:col-span-2 p-6 rounded-2xl shadow-sm border border-slate-200 bg-white`}>
  
  <div class="flex flex-col gap-y-10 justify-center ">

    {blok.icon.filename.length > 0 && 
  
      <Image src={blok.icon.filename} alt="" class="mt-2 shrink-0 w-16 h-16" inferSize/>
  
    }
    <div class="flex flex-col gap-y-2">
      <div class="flex items-baseline gap-x-2">
        <p class=" text-5xl md:text-6xl text-heading">{blok.number}</p>
        <span class="text-3xl md:text-4xl text-heading">{blok.prefix}</span>
      </div>
      <p class="text-lg md:text-xl text-slate-600">{blok.label}</p>
    </div>
  </div>
  

</div>
